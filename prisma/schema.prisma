// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
  CUSTOMER
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH       // Used in POS
  CARD       // Used in POS & Web
  ONLINE     // Used in Web
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  role      Role     @default(CUSTOMER)
  password  String?  // For credential auth MVP
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String    @id @default(uuid())
  name      String
  brand     String
  category  String
  price     Float
  stock     Int
  sku       String?
  spec      String?
  badge     String?
  image     String?
  deletedAt DateTime? // <-- ADD THIS LINE FOR SOFT DELETES
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Order {
  id            String        @id @default(cuid())
  userId        String?       // Nullable if walk-in POS customer
  user          User?         @relation(fields: [userId], references: [id])
  status        OrderStatus   @default(PENDING)
  total         Float
  paymentMethod PaymentMethod
  isPosOrder    Boolean       @default(false) // Distinguish Web vs POS sales
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Price at the time of purchase
}